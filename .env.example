# AttendX — Environment Configuration
# Copy this file to .env and set your values.
# (All fields are optional — defaults work for local development)

# ── Web server ────────────────────────────────────────────────
# PORT=5000
# HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────
# Path to the SQLite database file (auto-created on first run)
# DATABASE_PATH=data/attendx.db

# ── Security ──────────────────────────────────────────────────
# Change this to a random string in production!
# SECRET_KEY=change-me-to-a-random-secret

# ── Camera ────────────────────────────────────────────────────
# Camera device index (0 = default webcam, 1 = second camera)
# CAMERA_DEVICE_ID=0

# ── Face Recognition ──────────────────────────────────────────
# Cosine similarity threshold (0 = loose, 1 = strict)
# RECOGNITION_THRESHOLD=0.45

# Cooldown in minutes before the same face is logged again
# COOLDOWN_MINUTES=5

# ── Anti-Spoofing ─────────────────────────────────────────────
# Set to 1 to disable liveness checks (useful for testing)
# DISABLE_ANTISPOOFING=0

# ── Logging ───────────────────────────────────────────────────
# LOG_LEVEL=INFO
