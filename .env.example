# Smart Attendance System – Environment Configuration
# Copy this file to .env and adjust values for your environment.
# These override settings in config/settings.py.

# Camera device ID (0 = default webcam, 1 = second camera, etc.)
# CAMERA_DEVICE_ID=0

# Face recognition similarity threshold (0.0 – 1.0)
# Lower = more permissive (more false accepts)
# Higher = more strict (more false rejects)
# RECOGNITION_THRESHOLD=0.55

# Cooldown period in minutes (prevents duplicate scans)
# COOLDOWN_MINUTES=5

# Set to "1" to disable anti-spoofing (useful for testing)
# DISABLE_ANTISPOOFING=0

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
